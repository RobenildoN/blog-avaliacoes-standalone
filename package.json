{
  "name": "blog-avaliacoes-standalone",
  "version": "1.0.0",
  "description": "Aplicação de avaliações com SQLite",
  "main": "main.js",
  "scripts": {
    "build": "node scripts/init-db.js",
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "body-parser": "^1.20.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "sequelize": "^6.37.1",
    "sqlite3": "^6.0.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "nodemon": "^3.1.0"
  },
  "overrides": {
    "yauzl": "3.2.1"
  },
  "keywords": [
    "blog",
    "avaliações",
    "mangas",
    "livros",
    "filmes",
    "séries",
    "cursos"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "build": {
    "appId": "com.blogavaliacoes.standalone",
    "productName": "Blog de Avaliações - Autônomo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.md",
      "!docs/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blog de Avaliações"
    }
  }
}
