{
  "name": "blog-avaliacoes-standalone",
  "version": "4.5.0",
  "description": "Aplicação de avaliações com SQLite",
  "main": "main.js",
  "scripts": {
    "build": "node scripts/init-db.js",
    "start": "electron .",
    "dev": "nodemon --exec electron .",
    "dist": "electron-builder",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "electron-log": "^5.4.3",
    "node-cron": "^4.2.1",
    "sequelize": "^6.37.1",
    "showdown": "^2.1.0",
    "sqlite3": "^6.0.1"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "jest": "^30.3.0",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.5"
  },
  "overrides": {
    "yauzl": "3.2.1"
  },
  "keywords": [
    "blog",
    "avaliações",
    "mangas",
    "livros",
    "filmes",
    "séries",
    "cursos"
  ],
  "author": "Seu Nome",
  "license": "MIT",
  "build": {
    "appId": "com.blogavaliacoes.standalone",
    "productName": "Blog de Avaliações - Autônomo",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!dist/**/*",
      "!build/**/*",
      "!*.md",
      "!docs/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sqlite3/**/*"
    ],
    "win": {
      "target": "dir"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Blog de Avaliações"
    }
  }
}
